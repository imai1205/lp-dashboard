# Turso (libSQL) ──────────────────────────────────────────────
# 本番:  turso db show <db-name> --url  /  turso db tokens create <db-name>
# ローカル開発: SQLiteファイルを指定するだけ (auth tokenは不要)
TURSO_DATABASE_URL="file:./local.db"
TURSO_AUTH_TOKEN=""

# Better Auth ──────────────────────────────────────────────
# openssl rand -base64 32 で生成
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth (Google Cloud Console > Credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# 埋め込みコード/tracker.js のオリジン
# 本番では https://<your-domain> に切替
NEXT_PUBLIC_APP_URL="http://localhost:3000"
