# =============================================================
# LP Analytics — 環境変数 (Vercel本番デプロイ対応)
# =============================================================
# ローカル: このファイルを .env.local にコピーして埋める。
# 本番   : Vercel Project Settings > Environment Variables に同じキーを登録。
# =============================================================

# Turso (libSQL) ──────────────────────────────────────────────
# 本番:  turso db show <db-name> --url  /  turso db tokens create <db-name>
# ローカル開発: SQLiteファイルパス (auth tokenは不要)
TURSO_DATABASE_URL="file:./local.db"
TURSO_AUTH_TOKEN=""

# Better Auth ──────────────────────────────────────────────
# openssl rand -base64 32 で生成。本番とローカルで別の値を推奨。
BETTER_AUTH_SECRET=""
# 本番URLを基準にする (現行: https://lp-dashboard-eight.vercel.app)。
# 未設定なら VERCEL_URL → 本番URL固定 の順でフォールバック。
BETTER_AUTH_URL="https://lp-dashboard-eight.vercel.app"

# Google OAuth (Google Cloud Console > Credentials) ────────
# OAuth Client Type は "Web application"。
# Authorized redirect URIs に本番URLを登録:
#   https://lp-dashboard-eight.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# 埋め込みコード/tracker.js のオリジン ─────────────────────
# 外部LPに貼り付ける <script src="..."> の URL になるため、必ず本番URLを設定。
NEXT_PUBLIC_APP_URL="https://lp-dashboard-eight.vercel.app"

# 公開デモLP (/lp-saas-demo) ─────────────────────────────
# 本SaaSで site を作成 → site.id をここにセット。
# /lp-saas-demo のCTAボタンで tracker.js が events を送る先になる。
# 未設定だとデモLPがエラーバナー表示で機能停止する。
NEXT_PUBLIC_DEMO_SITE_ID=""

# 公開デモLP の GA4 計測ID (任意) ─────────────────────────
# 設定すると /lp-saas-demo に gtag.js が読み込まれ、
# utm_source/utm_medium が GA4 に送られて analytics_sources_daily に反映される。
# 形式: G-XXXXXXXXXX (本SaaSのDataAPI用 PropertyID とは別物)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=""

# GA4 Data API ────────────────────────────────────────────
# 認証はログインユーザーの Google OAuth トークン経由 (Service Account 不要)。
# 上の GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET が GA4 にも流用される。
#
# 準備:
#  1. Google Cloud Console > APIs & Services > Library で
#     「Google Analytics Data API」を有効化
#  2. OAuth 同意画面の Scopes に
#     https://www.googleapis.com/auth/analytics.readonly を追加
#  3. テスト中は OAuth 同意画面の Test users にメールを追加
#  4. 既存ユーザーは一度ログアウト → 再ログインで GA4 アクセスを再承諾
#  5. 各サイトの編集画面で GA4プロパティID を設定
#
# ※ GA4プロパティへのアクセス権は「ログイン中のGoogleアカウント自身」に依存する。

# Vercel Cron ─────────────────────────────────────────────
# 毎日 18:00 UTC (= JST 03:00) に /api/cron/ga4-sync を叩いて GA4 同期する。
# 設定: vercel.json + CRON_SECRET 環境変数。
# openssl rand -base64 32 等で生成し、Vercel Project Settings にも同値登録する。
# Vercel Cron は CRON_SECRET があれば自動で Authorization: Bearer <secret> を付ける。
CRON_SECRET=""

# =============================================================
# 自動付与 (設定不要 / Vercel が自動セット)
# =============================================================
# VERCEL_URL — Vercel が <project>-<hash>.vercel.app 形式で自動セット
#              (プロトコル無しの hostname だけ)
# VERCEL_ENV — "production" / "preview" / "development"
# NODE_ENV   — Next.js が build/runtime で自動セット
# =============================================================
